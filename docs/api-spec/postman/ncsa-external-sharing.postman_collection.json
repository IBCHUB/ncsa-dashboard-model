{
  "info": {
    "name": "NCSA External Threat Sharing API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "External sharing endpoints for partner organizations. Source: docs/api-spec/ncsa-external-sharing-openapi.yaml"
  },
  "item": [
    {
      "name": "Partner Profile & Lookups",
      "item": [
        {
          "name": "Get Partner Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/profile",
              "query": []
            }
          }
        },
        {
          "name": "List IOC Types",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/lookups/ioc-types",
              "query": []
            }
          }
        },
        {
          "name": "List Threat Types",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/lookups/threat-types",
              "query": []
            }
          }
        },
        {
          "name": "List Severities",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/lookups/severities",
              "query": []
            }
          }
        },
        {
          "name": "List TLP Levels",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/lookups/tlp-levels",
              "query": []
            }
          }
        },
        {
          "name": "List Export Formats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/lookups/export-formats",
              "query": []
            }
          }
        }
      ]
    },
    {
      "name": "Outbound Feed",
      "item": [
        {
          "name": "Get Incremental Changes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/changes?cursor={{cursor}}&since={{since}}&page_size={{page_size}}&tlp={{tlp}}&updated_after={{updated_after}}",
              "query": [
                {
                  "key": "cursor",
                  "value": "{{cursor}}",
                  "disabled": false
                },
                {
                  "key": "since",
                  "value": "{{since}}",
                  "disabled": false
                },
                {
                  "key": "page_size",
                  "value": "{{page_size}}",
                  "disabled": false
                },
                {
                  "key": "tlp",
                  "value": "{{tlp}}",
                  "disabled": false
                },
                {
                  "key": "updated_after",
                  "value": "{{updated_after}}",
                  "disabled": false
                }
              ]
            }
          }
        },
        {
          "name": "List Indicators",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/indicators?page={{page}}&page_size={{page_size}}&query={{query}}&tlp={{tlp}}&min_risk_score={{min_risk_score}}&start_date={{start_date}}&end_date={{end_date}}",
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}",
                  "disabled": false
                },
                {
                  "key": "page_size",
                  "value": "{{page_size}}",
                  "disabled": false
                },
                {
                  "key": "query",
                  "value": "{{query}}",
                  "disabled": false
                },
                {
                  "key": "tlp",
                  "value": "{{tlp}}",
                  "disabled": false
                },
                {
                  "key": "min_risk_score",
                  "value": "{{min_risk_score}}",
                  "disabled": false
                },
                {
                  "key": "start_date",
                  "value": "{{start_date}}",
                  "disabled": false
                },
                {
                  "key": "end_date",
                  "value": "{{end_date}}",
                  "disabled": false
                }
              ]
            }
          }
        },
        {
          "name": "Get Indicator Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/indicators/{{indicator_id}}",
              "query": []
            }
          }
        },
        {
          "name": "Get Indicator Observations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/indicators/{{indicator_id}}/observations?page={{page}}&page_size={{page_size}}",
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}",
                  "disabled": false
                },
                {
                  "key": "page_size",
                  "value": "{{page_size}}",
                  "disabled": false
                }
              ]
            }
          }
        },
        {
          "name": "Get Indicator Relationships",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{external_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/indicators/{{indicator_id}}/relationships",
              "query": []
            }
          }
        }
      ]
    },
    {
      "name": "Inbound Contributions",
      "item": [
        {
          "name": "Submit Indicator",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{writer_api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ioc_value\": \"new-submit.example\",\n  \"ioc_type\": \"domain\",\n  \"title\": \"Partner phishing domain\",\n  \"description\": \"Phishing infrastructure shared by partner\",\n  \"threat_types\": [\"Phishing\"],\n  \"severity\": \"high\",\n  \"confidence\": 85,\n  \"tlp\": \"green\",\n  \"tags\": [\"credential-harvest\", \"thai-gov\"],\n  \"references\": [\"https://partner.example/report/1\"],\n  \"observed_at\": \"2026-03-12T01:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/external/indicators",
              "query": []
            }
          }
        },
        {
          "name": "Submit Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{writer_api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"incident_report\",\n  \"title\": \"Partner observed multiple indicators\",\n  \"description\": \"Callback and phishing indicators observed in same case\",\n  \"severity\": \"critical\",\n  \"confidence\": 90,\n  \"tlp\": \"amber\",\n  \"observed_at\": \"2026-03-12T02:00:00Z\",\n  \"indicators\": [\n    {\n      \"ioc_value\": \"203.0.113.200\",\n      \"ioc_type\": \"ip\"\n    },\n    {\n      \"ioc_value\": \"https://evil.example/login\",\n      \"ioc_type\": \"url\"\n    }\n  ],\n  \"references\": [\"https://partner.example/report/2\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/external/events",
              "query": []
            }
          }
        },
        {
          "name": "Submit Bulk Payload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{writer_api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"default_tlp\": \"amber\",\n  \"dedupe_strategy\": \"indicator_id\",\n  \"items\": [\n    {\n      \"kind\": \"indicator\",\n      \"ioc_value\": \"bulk-ip.example\",\n      \"ioc_type\": \"domain\",\n      \"description\": \"Bulk IOC\",\n      \"severity\": \"medium\",\n      \"confidence\": 70\n    },\n    {\n      \"kind\": \"event\",\n      \"event_type\": \"bulk_event\",\n      \"description\": \"Bulk event IOC\",\n      \"severity\": \"high\",\n      \"confidence\": 80,\n      \"indicators\": [\n        {\n          \"ioc_value\": \"198.51.100.11\",\n          \"ioc_type\": \"ip\"\n        }\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/external/bulk",
              "query": []
            }
          }
        },
        {
          "name": "Get Submission Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{writer_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/submissions/{{submission_id}}",
              "query": []
            }
          }
        },
        {
          "name": "Revoke Submission",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{writer_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/submissions/{{submission_id}}/revoke",
              "query": []
            }
          }
        }
      ]
    },
    {
      "name": "Export Feed",
      "item": [
        {
          "name": "Create Export Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{writer_api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"format\": \"{{external_format}}\",\n  \"tlp\": \"amber\",\n  \"ioc_types\": [\"domain\", \"ip\"],\n  \"threat_types\": [\"Phishing\"],\n  \"severities\": [\"critical\", \"high\"],\n  \"min_risk_score\": 80\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/external/exports",
              "query": []
            }
          }
        },
        {
          "name": "Get Export Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{writer_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/exports/{{external_export_id}}",
              "query": []
            }
          }
        },
        {
          "name": "Download Export File",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{writer_api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/external/exports/{{external_export_id}}/download",
              "query": []
            }
          }
        }
      ]
    }
  ],
  "variable": []
}
